---
import '../styles/global.css';
const { title, description = 'Neutral, citation-ready sewing and embroidery machine research.' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site || 'https://stitchandspec.com').toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="deployment-check" content="github-cloudflare-2026-06-21-0324-utc" />
    <link rel="canonical" href={canonical} />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand" aria-label="Stitch and Spec home"><span class="brand-mark">S</span><span>Stitch <em>&amp;</em> Spec</span></a>
      <nav aria-label="Primary navigation">
        <a href="/research-graph/">Research map</a>
        <a href="/best-sewing-embroidery-machine-for-beginners/">Beginner guide</a>
        <a href="/brother-se700-vs-se2000/">SE700 vs SE2000</a>
        <a href="/editorial-policy/">Editorial policy</a>
      </nav>
    </header>
    <main><slot /></main>
    <footer>
      <div class="footer-inner">
        <div>
          <strong>Stitch &amp; Spec</strong>
          <p>Project-first sewing and embroidery machine research for buyers who want clarity before spending real money.</p>
        </div>
        <div class="footer-links">
          <a href="/affiliate-disclosure/">Affiliate disclosure</a>
          <a href="/editorial-policy/">Editorial policy</a>
          <a href="/research-graph/">Research map</a>
        </div>
      </div>
    </footer>
  </body>
</html>
