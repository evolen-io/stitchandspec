---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Affiliate Disclosure | Stitch & Spec">
  <article class="policy-page">
    <header class="page-hero compact">
      <p class="publication-kicker">Reader transparency</p>
      <h1>Affiliate disclosure</h1>
      <p class="lead">Some outbound merchant links may become affiliate links after program approval. That can generate commission at no additional cost to the reader.</p>
    </header>
    <section class="policy-section">
      <h2>How affiliate availability is handled</h2>
      <p>Affiliate availability does not determine recommendations; machine coverage is based on project fit, specifications, sources, and update history.</p>
    </section>
  </article>
</BaseLayout>
