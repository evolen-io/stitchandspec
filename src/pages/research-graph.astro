---
import BaseLayout from '../layouts/BaseLayout.astro';
import { researchPages } from '../data/pages';
const byCluster = Object.groupBy(researchPages, (page) => page.cluster);
const humanizeCluster = (cluster) => cluster.split('-').map((word) => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
const clusterId = (cluster) => cluster === 'beginner-buying' ? 'guides' : cluster;
---
<BaseLayout title="Research Graph | Stitch & Spec">
  <article class="graph-page">
    <header class="page-hero compact">
      <p class="publication-kicker">Research map</p>
      <h1>Research graph</h1>
      <p class="lead">Browse 25 sewing and embroidery machine guides by project, material, machine type, and buying decision.</p>
    </header>
    <section class="graph-intro" aria-labelledby="graph-index-heading">
      <h2 id="graph-index-heading">Browse by buyer decision</h2>
      <p>Use this page to find guides on machine comparisons, materials, workflow, service, and upgrade risk.</p>
    </section>
    {Object.entries(byCluster).map(([cluster, pages]) => (
      <section class="graph-cluster" id={clusterId(cluster)}>
        <h2>{humanizeCluster(cluster)}</h2>
        <ul>{pages?.map((page) => <li><a href={`/${page.slug}/`}>{page.title}</a> — {page.buyerQuestion}</li>)}</ul>
      </section>
    ))}
  </article>
</BaseLayout>
