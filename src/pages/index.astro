---
import BaseLayout from '../layouts/BaseLayout.astro';
import { researchPages } from '../data/pages';

const prioritySlugs = [
  'best-sewing-embroidery-machine-for-beginners',
  'embroidery-hoop-size-explained',
  'brother-se700-vs-se2000',
  'embroidery-machine-for-small-business',
  'sewing-machine-for-denim-and-canvas',
  'what-supplies-do-you-need-for-machine-embroidery',
  'embroidery-machine-for-shirts',
  'best-sewing-machine-for-bag-making',
  'embroidery-stabilizer-guide',
  'embroidery-software-for-beginners',
  'industrial-vs-domestic-sewing-machine'
];

const orderedGuides = prioritySlugs
  .map((slug) => researchPages.find((page) => page.slug === slug))
  .filter(Boolean);

const [leadGuide, noteOne, noteTwo, ...supportingGuides] = orderedGuides;

const topicIndex = [
  { label: 'Embroidery machines', href: '/best-sewing-embroidery-machine-for-beginners/' },
  { label: 'Sewing machines', href: '/sewing-machine-for-denim-and-canvas/' },
  { label: 'Combo machines', href: '/brother-se700-vs-se2000/' },
  { label: 'Beginner picks', href: '/best-sewing-embroidery-machine-for-beginners/' },
  { label: 'Comparison research', href: '/research-graph/' }
];

const categoryTone = (cluster = '') => {
  if (cluster.includes('beginner') || cluster.includes('business')) return 'priority';
  if (cluster.includes('embroidery') || cluster.includes('software')) return 'mechanics';
  return 'evergreen';
};
---
<BaseLayout title="StitchAndSpec | Sewing and Embroidery Machine Research" description="Research-backed sewing and embroidery machine guides for buyers choosing by project, hoop size, fabric handling, workflow, and upgrade risk.">
  <section class="home-rebuild" aria-labelledby="home-title">
    <div class="hero-masthead">
      <p class="publication-kicker">Independent sewing and embroidery machine research</p>
      <h1 id="home-title">StitchAndSpec</h1>
      <p class="hero-thesis">Research-backed sewing and embroidery machine guides for buyers who want to understand hoop size, fabric handling, stitch control, stabilizers, service access, and upgrade risk before they spend real money.</p>
    </div>

    <div class="research-desk" aria-label="Current research desk">
      <article class="desk-feature">
        <p class="desk-label">Current research desk</p>
        <h2>Choose the machine for the thing you actually make.</h2>
        <p>Start with the constraint that changes your project: embroidery field, fabric thickness, feed control, repeat hooping, or service path. The guide structure is built to move from anxiety to a practical shortlist.</p>
        <a class="button primary" href="/best-sewing-embroidery-machine-for-beginners/">Start with the beginner guide</a>
      </article>

      <aside class="desk-secondary" aria-label="Research shortcuts">
        <a href="/embroidery-hoop-size-explained/">
          <span>Secondary guide</span>
          <strong>Embroidery hoop size explained</strong>
          <small>Why 4 × 4, 5 × 7, and larger fields change what fits in one stitch-out.</small>
        </a>
        <div class="topic-index">
          <span>Topic index</span>
          <ul>
            {topicIndex.map((topic) => <li><a href={topic.href}>{topic.label}</a></li>)}
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <section class="home-guides" aria-labelledby="guide-listing-title">
    <div class="guide-intro">
      <p class="publication-kicker">Guide listing</p>
      <h2 id="guide-listing-title">A curated table of contents, not a stack of identical cards.</h2>
      <p>The highest-risk buying decision leads. Two compact research notes follow. Supporting guides change format by purpose: feature article, research note, comparison row, and paired reference entries.</p>
    </div>

    <div class="guide-layout">
      {leadGuide && (
        <a class="guide-feature" href={`/${leadGuide.slug}/`}>
          <span class:list={["category-cue", categoryTone(leadGuide.cluster)]}>{leadGuide.cluster.replaceAll('-', ' ')}</span>
          <strong>{leadGuide.title}</strong>
          <span>{leadGuide.bluf}</span>
          <em>Read the lead guide</em>
        </a>
      )}

      <div class="guide-stream">
        <div class="research-notes" aria-label="Compact research notes">
          {[noteOne, noteTwo].filter(Boolean).map((page) => (
            <a class="research-note" href={`/${page.slug}/`}>
              <span class:list={["category-cue", categoryTone(page.cluster)]}>{page.cluster.replaceAll('-', ' ')}</span>
              <strong>{page.title}</strong>
              <span>{page.buyerQuestion}</span>
            </a>
          ))}
        </div>

        <div class="supporting-guides" aria-label="Supporting guides">
          {supportingGuides.map((page, index) => (
            <a class:list={["support-guide", index === 1 && "comparison-row", index === 4 && "wide-reference"]} href={`/${page.slug}/`}>
              <span class:list={["category-cue", categoryTone(page.cluster)]}>{page.cluster.replaceAll('-', ' ')}</span>
              <strong>{page.title}</strong>
              <span>{index === 1 ? page.bluf : page.buyerQuestion}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
